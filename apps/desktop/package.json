{
  "name": "@florin/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.cjs",
  "scripts": {
    "build:main": "node scripts/build-main.mjs",
    "dev": "node scripts/build-main.mjs && electron .",

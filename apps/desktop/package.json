    "electron-updater": "^6.3.0",
    "next": "^15.5.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  }
}
